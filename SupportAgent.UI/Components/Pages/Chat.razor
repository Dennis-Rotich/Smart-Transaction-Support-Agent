@page "/"
@using SupportAgent.UI.Models
@using SupportAgent.UI.Services
@rendermode InteractiveServer
@inject McpClientService McpService
@inject UploadDocumentService UploadService
@inject PaymentService PaymentService

<PageTitle>Smart Support Agent</PageTitle>

<div class="chat-container">
    <div class="chat-header">
        <h2>Pesapal Smart Support</h2>
    </div>

    <div class="message-history">
        @if (!Messages.Any())
        {
            <div class="empty-state">How can I help you with your transactions today?</div>
        }
        else
        {
            @foreach (var message in Messages)
            {
                <div class="message-row @(message.Role.ToLower())">
                    <div class="message-bubble">
                        <div class="message-content">@message.Content</div>
                        <div class="message-time">@message.Timestamp.ToString("t")</div>
                    </div>
                </div>
            }
        }
        @if(_isTyping)
        {
            <div class="message-row eldo">
                <div class="message-bubble" style="opacity:0.8;">
                    <div class="message-content">Eldo is analyzing...</div>
                    <span class="" role="status" aria-hidden="true"></span>
                </div>
            </div>
        }
        @if(!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="message-row eldo">
                <div class="message-bubble error">
                    <div class="message-content">@_errorMessage</div>
                </div>
            </div>
        }
    </div>

    @if (ShowSecurePaymentForm)
    {
        <div class="secure-intake-card">
            <h4>Secure Payment Generation</h4>
            <p>Please provide an email for your receipt to open the secure payment portal.</p>
            
            <input type="email" @bind="userEmail" placeholder="Email Address" />
            <input type="number" @bind="amount" placeholder="Amount" />
            <input type="text" @bind="currency" placeholder="currency" />
            <button @onclick="InitiatePesaPalOrder" disabled="@isProcessing">
                Generate Payment Link
            </button>
        </div>
    }

    @if (ShowIframeModal)
    {
        <div class="modal-overlay">
            <div class="modal-content">
                <button class="close-btn" @onclick="() => ShowIframeModal = false">Close X</button>
            
                <iframe src="@IframePaymentUrl" width="100%" height="600px" frameborder="0"></iframe>
            </div>
        </div>
    }

    @if(selectedFile != null)
    {
        <div class="file-staging-area">
            <span class="file-icon">📄</span>
            <span class="file-name">@selectedFile.Name</span>
            <span class="file-size">(@(selectedFile.Size / 1024) KB)</span>
            <button class="remove-file-btn" @onclick="clearFile" disabled="@IsLoading">✖</button>
        </div>
    }

    @if(!string.IsNullOrEmpty(FileError))
    {
        <div class="file-error-text">@FileError</div>
    }   

    <div class="chat-input-area">
        <div class="upload-wrapper">
            <label for="fileInput" class="upload-btn @(IsLoading ? "disabled": "")" >        
                📎
            </label>
            <InputFile id="fileInput"
                OnChange="HandleFileSelected"
                style="display:none"
                disabed="@IsLoading"
                accept=".txt,.md,.pdf,.csv,.log"/>
        </div>
        <input type="text"
            class="prompt-input"
               placeholder="Ask a question or upload a document..."            
               @bind="CurrentPrompt"
               @bind:event="oninput"
               @onkeyup="HandleKeyUp"
               disabled="@IsLoading"/>
        <button class="send-btn" @onclick="sendMessage" disabled="@(string.IsNullOrWhiteSpace(CurrentPrompt) && selectedFile == null || IsLoading)">
            @(IsLoading ? "..." : "Send")
        </button>
    </div>
</div>

@code{
    private List<ChatMessage> Messages = new();
    private string CurrentPrompt = string.Empty;
    private bool IsLoading = false;

    private bool ShowSecurePaymentForm = false;
    private string userEmail = string.Empty;
    private decimal amount = 0;
    private string currency = "KES";
    private bool isProcessing = false;

    private bool ShowIframeModal = false;
    private string IframePaymentUrl = string.Empty;

    private IBrowserFile? selectedFile;
    private string FileError = string.Empty;

    private const long MaxFileSize = 5 * 1024 * 1024;
    private readonly string[] AllowedExtensions = new[] { ".txt", ".md", ".pdf", ".csv", ".log" };

    private bool _isTyping = false;
    private string _errorMessage = string.Empty;

    private void HandleFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        FileError = string.Empty;

        if(file == null)
        {
            FileError = "No file selected.";
            return;
        }

        if (file.Size > MaxFileSize)
        {
            FileError = $"{file.Name} size exceeds the 5MB limit.";
            selectedFile = null;
            return;
        }
        var extension = Path.GetExtension(file.Name).ToLower();
        if (!AllowedExtensions.Contains(extension))
        {
            FileError = $"{extension} files are not supported. Please upload TXT, MD, PDF, CSV, or LOG.";
            return;
        }
        selectedFile = file;
        StateHasChanged();
    }

    private void clearFile()
    {
        selectedFile = null;
        FileError = string.Empty;
        StateHasChanged();
    }

    private async void sendMessage()
    {
        if (string.IsNullOrWhiteSpace(CurrentPrompt) && selectedFile == null)
            return;

        IsLoading = true;
        StateHasChanged();
        try{
            if(selectedFile != null){
                Messages.Add(new ChatMessage { Role = "User", Content = $"[Uploading file: {selectedFile.Name}...]" });
                StateHasChanged();
            
                var uploadResult = await UploadService.UploadDocumentAsync(selectedFile);

                if(uploadResult != null){
                    Messages.Add(new ChatMessage { Role = "Eldo", Content = "File successfully stored." });
                } else{
                    Messages.Add(new ChatMessage { Role = "Eldo", Content = "File upload failed." });
                }

                selectedFile = null;
                FileError = string.Empty;
            }

            if(!string.IsNullOrWhiteSpace(CurrentPrompt)){
                Messages.Add(new ChatMessage { Role = "User", Content = CurrentPrompt });
                var userText = CurrentPrompt;
                CurrentPrompt = string.Empty;

                _isTyping = true;
                _errorMessage = string.Empty;
                StateHasChanged(); 

                try
                {
                    var response = await McpService.SendPromptAsync(userText);
                    Console.WriteLine(response);
                    if(response.Contains("{\"ui_command\":\"RENDER_SECURE_PAYMENT_INTAKE\"}")){
                        ShowSecurePaymentForm = true;
                        StateHasChanged();
                    }
                    else{
                        Messages.Add(new ChatMessage { Role = "Eldo", Content = response, Timestamp = DateTime.Now });
                    }
                }
                catch (TaskCanceledException)
                {
                    _errorMessage = "The analysis took too long and timed out. Please try again.";
                }
                catch (Exception ex)
                {
                    _errorMessage = $"System Error: {ex.Message}";
                }
                finally
                {
                    _isTyping = false;
                    StateHasChanged();
                }
            }     
        } catch(Exception ex)
        {
            Messages.Add(new ChatMessage
            {
                Role = "Eldo",
                Content = $"Error: {ex.Message}",
                Timestamp = DateTime.Now
            });
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task InitiatePesaPalOrder()
    {
        isProcessing = true;
        
        var result = await PaymentService.GeneratePaymentLinkAsync(userEmail, amount, currency);

        if (result?.RedirectUrl != null)
        {
            OpenIframeModal(result.RedirectUrl);
            
            ShowSecurePaymentForm = false;
            userEmail = string.Empty; 
            isProcessing = false;
            
            Messages.Add(new ChatMessage {Role = "Eldo", Content = "Secure payment link generated and opened."});
            StateHasChanged();
        }
        else
        {
            isProcessing = false;
            Messages.Add(new ChatMessage{Role = "Eldo", Content = "Failed to generate the payment link. Please try again."});
            StateHasChanged();
        }
    }

    private void HandleKeyUp(KeyboardEventArgs e)
    {
        if(e.Key == "Enter")
        {
            sendMessage();    
        }
    }

    private void OpenIframeModal(string url)
    {
        IframePaymentUrl = url;
        ShowIframeModal = true;
        StateHasChanged();
    }
}